# MyTermux 本地测试环境变量样本
# 使用方式:
#   cp .env.example .env
#   按需修改后执行: pnpm start:local:test

# -----------------------------------------------------------------------------
# Web Client
# -----------------------------------------------------------------------------
VITE_HOST=127.0.0.1
VITE_PORT=62100
VITE_HTTPS=false
VITE_RELAY_URL=ws://127.0.0.1:62200/ws
VITE_API_BASE=/api
VITE_MYTERMUX_WEB_LINK_TOKEN=your-web-link-token

# -----------------------------------------------------------------------------
# Relay
# -----------------------------------------------------------------------------
RELAY_HOST=127.0.0.1
RELAY_PORT=62200
HOST=127.0.0.1
PORT=62200
MYTERMUX_WEB_LINK_TOKEN=your-web-link-token
MYTERMUX_DAEMON_LINK_TOKEN=your-daemon-link-token
RELAY_WEB_MASTER_KEY=your-32-byte-random-secret
RELAY_DB_PATH=
WEB_DB_PATH=
WEB_ADMIN_USERNAME=admin
WEB_ADMIN_PASSWORD=mytermux

# -----------------------------------------------------------------------------
# Daemon
# -----------------------------------------------------------------------------
RELAY_URL=ws://127.0.0.1:62200
DAEMON_HOST=127.0.0.1
DAEMON_PORT=62300
# MYTERMUX_DAEMON_TOKEN 由 daemon 初始化后写入 ~/.mytermux/daemon.db
# 可选：若不想每次 start 传 --daemon-link-token，可用
# pnpm --filter @mytermux/daemon relay-token -- --set '<daemon-link-token>'
# 将 daemon 侧使用的 MYTERMUX_DAEMON_LINK_TOKEN 写入 ~/.mytermux/daemon.db

# -----------------------------------------------------------------------------
# 本地测试统一不启用证书
# -----------------------------------------------------------------------------
TLS_CERT=
TLS_KEY=
