    "commander": "^13.1.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
