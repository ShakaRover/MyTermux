{
  "name": "@mytermux/daemon",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "mytermux": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js start",
    "start:fg": "node dist/index.js start -f",
    "stop": "node dist/index.js stop",
    "status": "node dist/index.js status",
    "token": "node dist/index.js token",
    "token:reset": "node dist/index.js token --reset",
    "relay-token": "node dist/index.js relay-token",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mytermux/shared": "workspace:*",
    "commander": "^13.1.0",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
