{
  "name": "@mycc/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "mycc": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
