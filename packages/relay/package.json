{
  "name": "@mytermux/relay",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "mytermux-server": "./dist/cli.js",
    "mytermux-relay": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --watch dist/cli.js start -f",
    "start": "node dist/cli.js start",
    "start:fg": "node dist/cli.js start -f",
    "stop": "node dist/cli.js stop",
    "status": "node dist/cli.js status",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mytermux/shared": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "commander": "^13.1.0",
    "hono": "^4.7.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  }
}
