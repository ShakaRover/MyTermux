{
  "name": "mytermux",
  "version": "1.0.0",
  "private": true,
  "description": "远程控制终端会话 - 通过 Web 界面随时随地查看和控制本地电脑上的终端会话",
  "keywords": [
    "remote-control",
    "terminal",
    "daemon"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "server:start:fg": "bash ./scripts/server/start-fg.sh",
    "server:start:bg": "bash ./scripts/server/start-bg.sh",
    "server:stop": "bash ./scripts/server/stop.sh",
    "daemon:start:fg": "bash ./scripts/daemon/start-fg.sh",
    "daemon:start:bg": "bash ./scripts/daemon/start-bg.sh",
    "daemon:stop": "bash ./scripts/daemon/stop.sh",
    "daemon:token:get": "bash ./scripts/daemon/get-token.sh",
    "daemon:token:reset": "bash ./scripts/daemon/reset-token.sh",
    "daemon:server-token:set": "bash ./scripts/daemon/set-server-token.sh",
    "local:start:fg": "bash ./scripts/local/start-all-fg.sh",
    "local:stop": "bash ./scripts/local/stop-all.sh",
    "start:local:test": "pnpm local:start:fg",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.0.0"
  }
}
